DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/datatalk
QUERY_DATABASE_URL=postgresql+psycopg://datatalk_reader:datatalk_reader@db:5432/datatalk

SECRET_KEY=change_this_secret_key_use_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

LLM_PROVIDER=mock
LLM_REQUEST_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=0.25

GEMINI_API_KEY=your_gemini_key_here
GEMINI_CHAT_MODEL=gemini-2.5-flash

OPENAI_API_KEY=your_openai_key_here
OPENAI_CHAT_MODEL=gpt-4o-mini

QUERY_MAX_ROWS=100
DEFAULT_QUERY_LIMIT=20
QUERY_STATEMENT_TIMEOUT_MS=5000
QUERY_LOCK_TIMEOUT_MS=1000

ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
